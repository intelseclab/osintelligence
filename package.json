{
  "name": "osintelligence.net",
  "version": "0.1",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint": "next lint",
    "start": "next start",
    "sync-readme": "node scripts/sync-readme.js",
    "watch-readme": "node scripts/watch-readme.js",
    "build:cloudflare": "opennextjs-cloudflare build && cp -r .open-next/cloudflare .open-next/middleware .open-next/server-functions .open-next/.build .open-next/assets/ && cp .open-next/worker.js .open-next/assets/_worker.js",
    "preview:cloudflare": "npm run build:cloudflare && wrangler dev --port 8789",
    "deploy:cloudflare": "npm run build:cloudflare && wrangler pages deploy --commit-dirty=true"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@next/third-parties": "^16.2.9",
    "@radix-ui/react-select": "2.1.4",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.4",
    "lucide-react": "^0.454.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7.60.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4.1.9",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.11",
    "postcss": "^8.5",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "1.3.3",
    "typescript": "^5",
    "wrangler": "^4.100.0"
  }
}
